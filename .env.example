# =========================================================================
# Greenify Environment Variables Example
# =========================================================================
# Copy this file to .env.local and replace the placeholder values.

# Supabase Configuration (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-api-key

# Fal AI Configuration (https://fal.ai/dashboard/keys)
FAL_KEY=your-fal-ai-api-key
